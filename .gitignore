# AI Data Analyst .gitignore

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.env
venv/
.venv/
env/

# Backend data dirs (don't commit user data)
backend/uploads/
backend/reports/
backend/*.db
backend/ai_data_analyst.db

# Node / Frontend
node_modules/
frontend/dist/
frontend/.env
.env.local
.env.production

# IDE
.idea/
.vscode/
*.sublime-project
*.sublime-workspace

# OS
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
logs/

# Test coverage
.coverage
htmlcov/
.pytest_cache/
